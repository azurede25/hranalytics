				"source": [
					"## 5_kpi_analytics\n",
					"\n",
					"\n",
					""
				]
			},
			{
				"cell_type": "code",
				"source": [
					"#Attrition Rate\n",
					"spark.sql(\"\"\"\n",
					"\n",
					"SELECT ROUND(COUNT(attrition_rate) * 100.0 / COUNT(*),2) AS attrition_rate FROM \n",
					"(SELECT CASE WHEN attrition_flag = 1 THEN 1 END AS attrition_rate FROM hranalytics_db.fact_employee_metrics) A\n",
					"\n",
					"\"\"\").show();"
				],
				"execution_count": 11
			},
			{
				"cell_type": "code",
				"source": [
					"# Resignation Drivers\n",
					"spark.sql(\"\"\"\n",
					"SELECT exit_reason, COUNT(*) AS cnt\n",
					"FROM hranalytics_db.silver_exit\n",
					"GROUP BY exit_reason\n",
					"ORDER BY cnt DESC;\n",
					"\"\"\").show()"
				],
				"execution_count": 13
			},
			{
				"cell_type": "code",
				"source": [
					"# Engagement Score\n",
					"spark.sql(\"\"\"\n",
					"SELECT AVG(survey_score) AS avg_engagement\n",
					"FROM hranalytics_db.fact_employee_metrics;\n",
					"\"\"\").show()"
				],
				"execution_count": 5
			},
			{
				"cell_type": "code",
				"source": [
					"# eNPS Score\n",
					"spark.sql(\"\"\"\n",
					"SELECT \n",
					"    ROUND((COUNT(CASE WHEN survey_score >= 9 THEN 1 END) -\n",
					"     COUNT(CASE WHEN survey_score <= 6 THEN 1 END)) * 100.0 / COUNT(*),2) AS eNPS\n",
					"FROM hranalytics_db.fact_employee_metrics;\n",
					"\"\"\").show()"
				],
				"execution_count": 15
			},
			{
				"cell_type": "code",
				"source": [
					"# Early Churn Detection\n",
					"spark.sql(\"\"\"\n",
					"SELECT emp_sk\n",
					"FROM hranalytics_db.fact_employee_metrics\n",
					"WHERE rating < 2 AND survey_score < 5;\n",
					"\"\"\").show()"
				],
				"execution_count": 16
			}
		]
	}
